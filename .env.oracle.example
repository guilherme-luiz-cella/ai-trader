# Oracle/Linux deployment env example
# Copy this file to .env on the Oracle VM and fill in all required secrets.

# Recommended Oracle deploy default:
# keep inference hosted and let the Oracle VM focus on frontend, backend, autopilot,
# and persistence instead of local model hosting.
LLM_ENABLED=true
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
PRIMARY_MODEL=llama-3.3-70b-versatile
PRIMARY_MODEL_PATH=
PRIMARY_MODEL_IS_TRAINED=false
ALLOW_MODEL_FALLBACK=false
LLM_API_KEY=

SIGNAL_API_HOST=0.0.0.0
SIGNAL_API_PORT=8765
BROKER=binance
CHECK_SYMBOL=BTC/USDT
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false
PROD_ALPHA_AUTO_RUN=true
PROD_ALPHA_BTC_PATH=/app/backtest/data/BTC-6h-1000wks-data.csv
PROD_ALPHA_ETH_PATH=/app/backtest/data/ETH-1d-1000wks-data.csv
PROD_ALPHA_SOL_PATH=/app/backtest/data/SOL-1d-1000wks-data.csv

APP_DOMAIN=
ACME_EMAIL=

AUTOPILOT_ALERTING_ENABLED=true
AUTOPILOT_TWILIO_ACCOUNT_SID=
AUTOPILOT_TWILIO_AUTH_TOKEN=
AUTOPILOT_TWILIO_FROM_NUMBER=
AUTOPILOT_TWILIO_TO_NUMBER=
AUTOPILOT_TWILIO_CHANNEL=whatsapp

AUTOPILOT_UNATTENDED_MIN_BURNIN_RUNS=8
AUTOPILOT_UNATTENDED_MAX_SKIP_RATE=0.60
AUTOPILOT_UNATTENDED_MAX_RECONCILIATION_INCIDENTS=0
AUTOPILOT_BURNIN_MAX_ERROR_RATE=0.10
AUTOPILOT_BURNIN_MIN_FINALIZATION_SUCCESS_RATE=1.00
