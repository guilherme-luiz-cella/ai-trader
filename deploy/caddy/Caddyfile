{
	email {$ACME_EMAIL}
	auto_https disable_redirects
}

(frontend_routes) {
	encode zstd gzip

	handle_path /api/* {
		reverse_proxy signal-api:8765
	}

	handle /health {
		reverse_proxy signal-api:8765
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

(api_routes) {
	encode zstd gzip
	reverse_proxy signal-api:8765
}

:80 {
	import frontend_routes
}

{$API_DOMAIN:api.localhost}:80 {
	import api_routes
}

{$APP_DOMAIN:localhost} {
	tls {$ACME_EMAIL}
	import frontend_routes
}

{$API_DOMAIN:api.localhost} {
	tls {$ACME_EMAIL}
	import api_routes
}
