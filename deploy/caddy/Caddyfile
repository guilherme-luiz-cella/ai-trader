{
	email {$ACME_EMAIL}
	auto_https disable_redirects
}

(app_routes) {
	encode zstd gzip

	handle_path /api/* {
		reverse_proxy signal-api:8765
	}

	handle /health {
		reverse_proxy signal-api:8765
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

:80 {
	import app_routes
}

{$APP_DOMAIN:localhost} {
	tls {$ACME_EMAIL}
	import app_routes
}
