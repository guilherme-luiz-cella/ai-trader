FINNHUB_API_KEY=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false
BINANCE_TIMEOUT_SECONDS=30
BINANCE_BYPASS_ENV_PROXY=true

# Dashboard runtime
CHECK_SYMBOL=BTC/USDT
ACCOUNT_REFERENCE_USD=1000
AUTH_USERNAME=
AUTH_PASSWORD=

# Signal model runtime
MODEL_PATH=
DATASET_PATH=
BUY_THRESHOLD=0.52
SELL_THRESHOLD=0.48
ADAPTIVE_THRESHOLD_ENABLED=false
SIZE_MIN_CONFIDENCE=0.05
SIGNAL_ENGINE_MODE=classic
PROD_ALPHA_AUTO_RUN=true
PROD_ALPHA_TARGET_SYMBOL=BTC/USDT
PROD_ALPHA_BTC_PATH=/app/backtest/data/BTC-6h-1000wks-data.csv
PROD_ALPHA_ETH_PATH=/app/backtest/data/ETH-1d-1000wks-data.csv
PROD_ALPHA_SOL_PATH=/app/backtest/data/SOL-1d-1000wks-data.csv

# Dataset builder / training enrichment
DATA_SYMBOL=BTCUSDT
DATA_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DATA_TIMEFRAME=1h
DATA_LOOKBACK_DAYS=1460
NEWS_LOOKBACK_DAYS=1460
TARGET_HORIZON=1
TARGET_RETURN_THRESHOLD=0.006
TARGET_DOWNSIDE_THRESHOLD=-0.006

# Combined trainer defaults (cleaner labels + recency emphasis)
TEST_SIZE=0.2
RECENCY_WEIGHT_ENABLED=true
RECENCY_HALF_LIFE_DAYS=180
RECENCY_MIN_WEIGHT=0.30
RECENCY_MAX_WEIGHT=3.00

# Free macro + event signals
FRED_API_KEY=
FRED_SERIES_IDS=DFF,CPIAUCSL,UNRATE,DGS10,VIXCLS
FRED_BASE_URL=https://api.stlouisfed.org/fred
FRED_TIMEOUT_SECONDS=20
FRED_BYPASS_ENV_PROXY=true
EVENT_LOOKBACK_DAYS=1460
GDELT_CRYPTO_QUERY=bitcoin OR ethereum OR crypto OR stablecoin OR ETF OR SEC OR hack OR bankruptcy OR exchange
GDELT_MACRO_QUERY=Fed OR inflation OR CPI OR rates OR recession OR rate hike OR rate cut
GDELT_TIMEOUT_SECONDS=30
GDELT_BYPASS_ENV_PROXY=true
FNG_TIMEOUT_SECONDS=20
FNG_BYPASS_ENV_PROXY=true
COINGECKO_TIMEOUT_SECONDS=30
COINGECKO_BYPASS_ENV_PROXY=true
COINGECKO_SYMBOL_ID_MAP=BTCUSDT:bitcoin,ETHUSDT:ethereum,SOLUSDT:solana
COINGECKO_AUTO_MAP_ENABLED=true
SIZE_MIN_CONFIDENCE=0.05
DECISION_MIN_CONFIDENCE=0.55
TARGET_MONITOR_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
TARGET_MONITOR_MAX_ASSETS=3
TARGET_PRICE_MAP=BTCUSDT:80000,ETHUSDT:4500,SOLUSDT:250
TARGET_SURPASS_PCT=0.01
PROFIT_PARKING_STABLE_ASSET=USDT
STABLE_RESERVE_MIN_PCT=0.35

# Optional LLM overlay
LLM_ENABLED=false
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
PRIMARY_MODEL=llama-3.3-70b-versatile
PRIMARY_MODEL_PATH=
PRIMARY_MODEL_IS_TRAINED=false
ALLOW_MODEL_FALLBACK=false
FALLBACK_MODEL=
FALLBACK_MODEL_PATH=
LLM_MODEL=
LLM_LOCAL_MODEL_PATH=
LLM_API_KEY=
LLM_MERGE_ENABLED=true
LLM_MERGE_WEIGHT=0.25
LLM_CONFIDENCE_FLOOR=0.40
LLM_CONFIDENCE_SOFT_GATE=true
