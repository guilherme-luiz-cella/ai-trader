CONFIDENCE_MODEL_WEIGHT=0.50
CONFIDENCE_LLM_WEIGHT=0.30
CONFIDENCE_DATA_WEIGHT=0.20
CONFIDENCE_AGREEMENT_BONUS=0.10
LLM_TIMEOUT_SECONDS=30
LLM_BYPASS_ENV_PROXY=true

# Volatility-regime hybrid controller (recommended)
VOLATILITY_REGIME_ENABLED=true
VOLATILITY_LOOKBACK_ROWS=120
VOLATILITY_LOW_PCT=1.20
VOLATILITY_HIGH_PCT=2.50
VOLATILITY_EXTREME_PCT=4.00
MARKET_REGIME_TREND_LOOKBACK_ROWS=20
MARKET_REGIME_VOLUME_LOOKBACK_ROWS=20
MARKET_REGIME_TREND_THRESHOLD_PCT=1.0
MARKET_REGIME_VOLUME_SPIKE_RATIO=1.25
