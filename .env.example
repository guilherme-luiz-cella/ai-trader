FINNHUB_API_KEY=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false
BINANCE_TIMEOUT_SECONDS=30
BINANCE_BYPASS_ENV_PROXY=true

# Dashboard runtime
CHECK_SYMBOL=BTC/USDT
ACCOUNT_REFERENCE_USD=1000
AUTH_USERNAME=
AUTH_PASSWORD=

# Signal model runtime
MODEL_PATH=
DATASET_PATH=
BUY_THRESHOLD=0.55
SELL_THRESHOLD=0.45
ADAPTIVE_THRESHOLD_ENABLED=true

# Dataset builder / training enrichment
DATA_SYMBOL=BTCUSDT
DATA_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DATA_TIMEFRAME=1h
DATA_LOOKBACK_DAYS=1460
NEWS_LOOKBACK_DAYS=1460
TARGET_HORIZON=1
TARGET_RETURN_THRESHOLD=0.003
TARGET_DOWNSIDE_THRESHOLD=-0.003

# Free macro + event signals
FRED_API_KEY=
FRED_SERIES_IDS=DFF,CPIAUCSL,UNRATE,DGS10,VIXCLS
FRED_BASE_URL=https://api.stlouisfed.org/fred
FRED_TIMEOUT_SECONDS=20
FRED_BYPASS_ENV_PROXY=true
EVENT_LOOKBACK_DAYS=1460
GDELT_CRYPTO_QUERY=bitcoin OR ethereum OR crypto OR stablecoin OR ETF OR SEC OR hack OR bankruptcy OR exchange
GDELT_MACRO_QUERY=Fed OR inflation OR CPI OR rates OR recession OR rate hike OR rate cut
GDELT_TIMEOUT_SECONDS=30
GDELT_BYPASS_ENV_PROXY=true

# Optional LLM overlay
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen2.5:7b-instruct
LLM_API_KEY=
LLM_MERGE_ENABLED=true
LLM_MERGE_WEIGHT=0.20
LLM_CONFIDENCE_FLOOR=0.40
LLM_CONFIDENCE_SOFT_GATE=true
LLM_TIMEOUT_SECONDS=30
LLM_BYPASS_ENV_PROXY=true

# Volatility-regime hybrid controller (recommended)
VOLATILITY_REGIME_ENABLED=true
VOLATILITY_LOOKBACK_ROWS=120
VOLATILITY_LOW_PCT=1.20
VOLATILITY_HIGH_PCT=2.50
VOLATILITY_EXTREME_PCT=4.00
LLM_MERGE_WEIGHT_HIGH=0.35
HIGH_REGIME_REQUIRE_LLM_CONFIRMATION=true
HIGH_REGIME_MIN_LLM_CONFIDENCE=0.60
EXTREME_REGIME_FORCE_HOLD=true

# Split architecture (dashboard -> signal API)
SIGNAL_API_ENABLED=true
SIGNAL_API_URL=http://signal-api:8765/signal
SIGNAL_API_TIMEOUT_SECONDS=10
SIGNAL_API_BYPASS_ENV_PROXY=true

# Signal API server bind
SIGNAL_API_HOST=0.0.0.0
SIGNAL_API_PORT=8765
